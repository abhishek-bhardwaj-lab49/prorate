# .gitignore  (root)
# ──────────────────────────────────────────────────────────────────────────────
# Nix / direnv artefacts
# ──────────────────────────────────────────────────────────────────────────────

# direnv evaluation cache – regenerated automatically on `direnv allow`
.direnv/

# Nix result symlinks created by `nix build` / `nix develop`
result
result-*

# Nix evaluation cache files
.nix-*

# ──────────────────────────────────────────────────────────────────────────────
# Project-local Maven repository (populated by the Nix dev shell)
# ──────────────────────────────────────────────────────────────────────────────
.m2/

# ──────────────────────────────────────────────────────────────────────────────
# Maven build output
# ──────────────────────────────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ──────────────────────────────────────────────────────────────────────────────
# IDE files
# ──────────────────────────────────────────────────────────────────────────────

### IntelliJ IDEA ###
.idea/
*.iws
*.iml
*.ipr

### Eclipse / STS ###
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

### NetBeans ###
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

### VS Code ###
.vscode/

# ──────────────────────────────────────────────────────────────────────────────
# OS artefacts
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────────────────────────────────────
# Environment / secrets
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
